{
  "name": "@tickstem/core",
  "type": "module",
  "version": "0.1.0",
  "description": "Shared HTTP client and error types for Tickstem SDKs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/tickstem/node" },
  "homepage": "https://tickstem.dev",
  "keywords": ["tickstem", "sdk", "api"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "*",
    "typescript": "*",
    "vitest": "*",
    "@types/node": "*"
  }
}
