{
  "name": "@tickstem/verify",
  "type": "module",
  "version": "0.2.0",
  "description": "Tickstem email verification SDK for Node.js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tickstem/node"
  },
  "homepage": "https://tickstem.dev",
  "keywords": [
    "tickstem",
    "email",
    "verification",
    "validation",
    "sdk"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --dts-resolve",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@tickstem/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "*",
    "typescript": "*",
    "vitest": "*",
    "@types/node": "*"
  }
}
